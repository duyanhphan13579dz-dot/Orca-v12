# EditorConfig — https://editorconfig.org
# Chuẩn hóa định dạng mã nguồn giữa các editor/IDE.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Markdown: giữ lại khoảng trắng cuối dòng (hard line break)
[*.md]
trim_trailing_whitespace = false
