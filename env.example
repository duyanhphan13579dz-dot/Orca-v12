# ====================================================================
# Orca Financial — Mẫu biến môi trường (.env.example)
# --------------------------------------------------------------------
# KHÔNG đưa giá trị bí mật / thực tế vào file này.
# Sao chép thành `.env` (hoặc `.env.local`) rồi điền giá trị thật.
# Các biến NEXT_PUBLIC_* được expose ra trình duyệt — không để secret.
# ====================================================================

# ----- Cơ sở dữ liệu (BẮT BUỘC) -----
# Chuỗi kết nối PostgreSQL. Bắt buộc cho mọi truy vấn DB ở runtime.
DATABASE_URL=

# ----- Thông tin ứng dụng (public) -----
NEXT_PUBLIC_APP_NAME=Orca Financial
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ENV=production

# ----- Xác thực (NextAuth) -----
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# ----- AI / Mô hình ngôn ngữ -----
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ----- Nguồn dữ liệu thị trường -----
# Hiện hệ thống dùng tier miễn phí (không bắt buộc key). Điền nếu nâng cấp tier.
COINGECKO_API_KEY=
FINNHUB_API_KEY=
INVESTING_API_KEY=
WIDATA_API_KEY=
# URL của Agent VNStock (nếu triển khai dạng service riêng)
VNSTOCK_AGENT_URL=

# ----- Hạ tầng / vận hành -----
REDIS_URL=
LOG_LEVEL=info
# Khóa bảo vệ endpoint đồng bộ định kỳ (cron)
CRON_SECRET=
# Vercel tự inject khi deploy — để trống ở local
VERCEL_URL=
# Sentry giám sát lỗi
SENTRY_DSN=
